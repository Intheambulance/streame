        st.error("Please enter your Gemini API key in the sidebar.")
        st.stop()

    genai.configure(api_key=api_key)

    assignment = extract_text(assignment_file) or assignment_text
    rubric = extract_text(rubric_file) or rubric_text
    draft = extract_text(draft_file)

    notes = "\n\n=== NOTE ===\n".join([extract_text(f) for f in notes_files if f])
    readings = "\n\n=== READING ===\n".join([extract_text(f) for f in readings_files if f])
    samples = "\n\n=== SAMPLE ===\n".join([extract_text(f)[:1500] for f in samples_files if f])

    if not assignment.strip():
        st.error("Assignment information is required! Upload an Assignment file or paste instructions in the expander.")
        st.stop()

    # Robust Upload & Wait logic for videos
    uploaded_files = []
    if video_files:
        temp_dir = "temp_uploads"
        os.makedirs(temp_dir, exist_ok=True)
        for vf in video_files:
            try:
                temp_path = os.path.join(temp_dir, vf.name)
                # Write Streamlit UploadedFile content locally on disk
                with open(temp_path, "wb") as f:
                    f.write(vf.read())
                
                # Upload using genai client path
                uploaded = genai.upload_file(temp_path)
                
                status_placeholder = st.empty()
                status_placeholder.info(f"Uploading {vf.name} to Gemini... State: {uploaded.state.name}")
                
                # Wait until processing is complete
                while uploaded.state.name == "PROCESSING":
                    time.sleep(3)
                    uploaded = genai.get_file(uploaded.name)
                    status_placeholder.info(f"Processing video {vf.name}... State: {uploaded.state.name}")
                
                if uploaded.state.name == "FAILED":
                    status_placeholder.error(f"Processing failed for video {vf.name}")
                    raise Exception("Video file upload/processing failed on Gemini servers.")
                
                status_placeholder.success(f"Video {vf.name} processed successfully!")
                uploaded_files.append(uploaded)
                
                # Clean up local temporary file
                if os.path.exists(temp_path):
                    os.remove(temp_path)
            except Exception as e:
                st.warning(f"Failed to process video {vf.name}: {str(e)}")

    system_instruction = f"""
You are an expert assistant that mimics the user's writing style perfectly.

**User's Writing Style:**
{samples or "Natural, thoughtful, clear tone."}

**Core Rules:**
- Match tone, vocabulary, syntax structures, and analytical depth.
- Incorporate and address instructions from all upload materials carefully.
- Adhere strictly to the rubric details.
"""

    user_content = [f"""**Assignment:**\n{assignment}\n\n**Rubric:**\n{rubric}\n\n**Notes:**\n{notes or 'None'}\n\n**Readings:**\n{readings or 'None'}\n\n**Draft:**\n{draft or 'None'}"""]
    if uploaded_files:
        user_content.extend(uploaded_files)

    try:
        model_instance = genai.GenerativeModel(
            model_name=model,
            system_instruction=system_instruction,
            generation_config={"temperature": temperature, "max_output_tokens": 8000}
        )

        st.subheader("🎯 Generating Style-Aligned Output...")
        response_placeholder = st.empty()
        full_response = ""

        response = model_instance.generate_content(user_content, stream=True)

        for chunk in response:
            if chunk.text:
                full_response += chunk.text
                response_placeholder.markdown(full_response + "▌")
                time.sleep(0.01)

        response_placeholder.markdown(full_response)
        st.session_state.final_result = full_response

        # Save to database
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        assignment_summary = assignment[:150] + "..." if len(assignment) > 150 else assignment
        full_prompt = f"Assignment: {assignment[:1000]}...\nRubric: {rubric[:500]}...\nNotes: {notes[:500]}..."

        save_to_db(timestamp, assignment_summary, full_prompt, full_response, model)

    except Exception as e:
        st.error(f"Error during generation: {str(e)}")

